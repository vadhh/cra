# Copy to .env and fill in real values. Never commit a real .env with actual
# secrets in it except where the project has explicitly decided otherwise
# (see docs/gate3_security_audit_2026-07-24.md F-01 for this repo's current
# risk-accepted exception, tied to the HF Spaces pilot deployment).

# --- Core secrets (generate with: python -c "import secrets; print(secrets.token_hex(32))") ---
LDV_SECRET_KEY=YOUR_SECRET_KEY_HERE
# Generate with: python manage.py gen-key
LDV_ENCRYPTION_KEY=YOUR_FERNET_KEY_HERE

# --- Session / cookies ---
LDV_COOKIE_SECURE=0
LDV_PRODUCTION=0

# --- Database / retention ---
LDV_DB_PATH=ldv-backend/sydeco.db
LDV_RETENTION_DAYS=30

# --- First admin account (consumed by `python manage.py seed-admin`) ---
LDV_ADMIN_EMAIL=
LDV_ADMIN_PASSWORD=
# Admin role is restricted to this org name (auth.is_operator_org) — F-02 fix.
LDV_OPERATOR_ORG=Sydeco

# --- Translation ---
LDV_REMOTE_TRANSLATION=0
EXTERNAL_TRANSLATION_DISABLED=1
LIGHTML_TRANSLATOR_URL=
LDV_LIGHTML_ALLOW_INSECURE=0
LDV_LIGHTML_API_KEY=
LDV_LIGHTML_MAX_CHARS=50000

# --- Scoring ---
LDV_USE_MLP_SCORER=0
LDV_RISK_SCORER_PATH=data/risk_scorer.pkl

# --- CORS / debug ---
LDV_CORS_ORIGINS=
LDV_DEBUG=0

# --- Classifier confirmation thresholds ---
LDV_CLASSIFIER_CONFIRMATION_THRESHOLD=0.70
LDV_CLASSIFIER_HIGH_CONFIDENCE_THRESHOLD=0.85
LDV_CLASSIFIER_MINIMUM_MARGIN=0.15

# --- Download links ---
LDV_DOWNLOAD_LINK_TTL=3600
# Optional: rotate the download-link signing key independently of LDV_SECRET_KEY (F-03 fix).
LDV_DOWNLOAD_LINK_SECRET=

# --- Rate limiting ---
# memory:// only works correctly with a single gunicorn worker process (see
# docker-compose.yml's `-w 1 --threads 4` and start.sh). Use Redis if you run
# multiple worker processes.
LDV_RATELIMIT_STORAGE_URL=memory://
# Set to 1 only on the server process running the standalone validation
# scripts (tests/run_full_validation.py etc.) against a live server (F-11 fix).
LDV_TEST_RUNNER_BYPASS=0
# Number of trusted reverse-proxy hops in front of this app, for audit-log IP
# attribution (X-Forwarded-For). 0 = don't trust the header at all (F-10 fix).
LDV_TRUST_PROXY_HOPS=0

# --- Upload parsing limits (F-05 fix) ---
LDV_MAX_PDF_PAGES=500
LDV_MAX_DOCX_UNCOMPRESSED_MB=200
LDV_MAX_UPLOAD_MB=10
